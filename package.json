{
  "name": "symbiosis-stream-engine",
  "version": "1.0.0",
  "description": "Zero-buffer streaming proxy for cloud storage aggregation via Rclone RC",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "db:generate": "bunx drizzle-kit generate:pg",
    "db:push": "bunx drizzle-kit push:pg",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "drizzle-orm": "^0.30.7",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.20.17",
    "typescript": "^5.7.0"
  }
}
