# Symbiosis Stream Engine — Environment Configuration Example

# Server configuration
PORT=3000

# Connection string for Neon serverless PostgreSQL database (required)
DATABASE_URL=postgresql://[user]:[password]@[host]/[dbname]?sslmode=require

# Rclone Remote Control (RC) daemon configuration
RCLONE_RC_HOST=127.0.0.1
RCLONE_RC_PORT=5572

# Optional Rclone RC basic authentication credentials
# RCLONE_RC_USER=admin
# RCLONE_RC_PASS=supersecretpassword
